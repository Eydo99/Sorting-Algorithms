<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
       xmlns:fx="http://javafx.com/fxml"
       fx:controller="sorting.ui.ComparisonController"
       styleClass="root-container">

    <!-- ── CONTROL BAR ── -->
    <HBox styleClass="control-bar" alignment="CENTER_LEFT" spacing="16">

        <!-- Array Type -->
        <VBox styleClass="control-group" spacing="4">
            <Label text="ARRAY TYPE" styleClass="control-label"/>
            <ComboBox fx:id="arrayTypeCombo" styleClass="combo-input" prefWidth="140"/>
        </VBox>

        <!-- Size -->
        <VBox styleClass="control-group" spacing="4">
            <Label text="SIZE" styleClass="control-label"/>
            <TextField fx:id="arraySizeField" styleClass="text-input"
                       promptText="500" prefWidth="80"/>
        </VBox>

        <!-- Runs -->
        <VBox styleClass="control-group" spacing="4">
            <Label text="RUNS" styleClass="control-label"/>
            <TextField fx:id="runsField" styleClass="text-input"
                       promptText="5" prefWidth="80"/>
        </VBox>

        <Separator orientation="VERTICAL" styleClass="bar-divider"/>

        <!-- Algorithms -->
        <VBox styleClass="control-group" spacing="4">
            <Label text="ALGORITHMS" styleClass="control-label"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <CheckBox fx:id="checkBubble"    text="BubbleSort"    styleClass="algo-chip"/>
                <CheckBox fx:id="checkInsertion" text="InsertionSort" styleClass="algo-chip"/>
                <CheckBox fx:id="checkSelection" text="SelectionSort" styleClass="algo-chip"/>
                <CheckBox fx:id="checkMerge"     text="MergeSort"     styleClass="algo-chip"/>
                <CheckBox fx:id="checkQuick"     text="QuickSort"     styleClass="algo-chip"/>
                <CheckBox fx:id="checkHeap"      text="HeapSort"      styleClass="algo-chip"/>
            </HBox>
        </VBox>

        <Separator orientation="VERTICAL" styleClass="bar-divider"/>

        <!-- From File -->
        <VBox styleClass="control-group" spacing="4">
            <Label text="FROM FILE" styleClass="control-label"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button fx:id="selectFilesBtn" text="📂 Select Files"
                        styleClass="btn-ghost" onAction="#handleSelectFiles"/>
                <Label fx:id="selectedFilesLabel" text="No files selected"
                       styleClass="control-label"/>
            </HBox>
        </VBox>

        <!-- Action Buttons -->
        <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
            <HBox.margin>
                <Insets left="16"/>
            </HBox.margin>
            <Button fx:id="runSequentialBtn" text="▶  Run Sequential"
                    styleClass="btn-primary" onAction="#handleRunSequential"/>
            <Button fx:id="runParallelBtn"   text="⚡  Run Parallel"
                    styleClass="btn-accent"  onAction="#handleRunParallel"/>
            <Button fx:id="exportCsvBtn"     text="⬇  Export CSV"
                    styleClass="btn-ghost"   onAction="#handleExportCsv"/>
            <Button fx:id="clearBtn"         text="✕  Clear"
                    styleClass="btn-danger"  onAction="#handleClear"/>
        </HBox>

    </HBox>

    <!-- ── RESULTS TABLE ── -->
    <VBox VBox.vgrow="ALWAYS" styleClass="table-area" spacing="10">
        <VBox.margin><Insets top="16" right="20" left="20"/></VBox.margin>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="RESULTS" styleClass="section-label"/>
            <Label fx:id="resultCountLabel" styleClass="badge"/>
        </HBox>

        <TableView fx:id="resultsTable" VBox.vgrow="ALWAYS"
                   styleClass="data-table">
            <columns>
                <TableColumn fx:id="resultAlgoCol"  text="Algorithm"    prefWidth="120"  style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="resultSizeCol"  text="Size"         prefWidth="70" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="resultTypeCol"  text="Type"         prefWidth="100" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="resultNoOfRunsCol"  text="Runs"         prefWidth="100" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="resultMinRunTimeCol"   text="Min. Runtime(ns)"          prefWidth="50" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="resultMaxRunTimeCol"  text="Max. Runtime (ns)"    prefWidth="100" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="resultAverageCol"  text="Avg. Runtime (ns)"    prefWidth="100" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="resultCompCol"  text="Comparisons"  prefWidth="110" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="resultInterCol" text="Interchanges" prefWidth="110" style="-fx-alignment: CENTER;"/>
            </columns>
            <placeholder>
                <Label text="No results yet — add tasks and run" styleClass="table-placeholder"/>
            </placeholder>
        </TableView>
    </VBox>

    <!-- ── PENDING TASKS ── -->
    <VBox styleClass="table-area" spacing="10">
        <VBox.margin><Insets top="12" right="20" left="20"/></VBox.margin>

        <Label text="PENDING TASKS" styleClass="section-label"/>

        <TableView fx:id="pendingTasksTable" prefHeight="130"
                   styleClass="data-table">
            <columns>
                <TableColumn fx:id="pendingAlgoCol"     text="Algorithm" prefWidth="120"/>
                <TableColumn fx:id="pendingSizeCol"     text="Size"/>
                <TableColumn fx:id="pendingTypeCol"     text="Type"      prefWidth="120"/>
                <TableColumn fx:id="pendingRunsCol"     text="Runs"      prefWidth="70"/>
                <TableColumn fx:id="pendingFromFileCol" text="From File" prefWidth="90"/>
            </columns>
            <placeholder>
                <Label text="No pending tasks" styleClass="table-placeholder"/>
            </placeholder>
        </TableView>
    </VBox>

    <!-- ── SUMMARY BAR ── -->
    <HBox styleClass="summary-bar" alignment="CENTER_LEFT" spacing="32">
        <VBox.margin><Insets top="12"/></VBox.margin>

        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="AVG" styleClass="summary-label"/>
            <Label fx:id="avgLabel" text="--" styleClass="summary-value-avg"/>
        </HBox>

        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="MIN" styleClass="summary-label"/>
            <Label fx:id="minLabel" text="--" styleClass="summary-value-min"/>
        </HBox>

        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="MAX" styleClass="summary-label"/>
            <Label fx:id="maxLabel" text="--" styleClass="summary-value-max"/>
        </HBox>

    </HBox>

</VBox>